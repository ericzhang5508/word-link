<!-- Check result overlay -->
<div id="result-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-on-surface/40 backdrop-blur-sm hidden">
    <div class="bg-white p-10 max-w-md w-full text-center">
        <span id="result-icon" class="material-symbols-outlined text-5xl mb-4 block"></span>
        <h2 id="result-title" class="text-2xl font-black mb-2"></h2>
        <p id="result-message" class="text-sm text-on-surface-variant mb-6"></p>
        <button id="result-close" class="bg-primary text-on-primary px-6 py-2 text-xs font-bold tracking-widest uppercase hover:bg-primary-dim transition-all active:scale-95">
            Continue
        </button>
    </div>
</div>

<!-- Help modal -->
<div id="help-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-on-surface/40 backdrop-blur-sm hidden">
    <div class="bg-white p-10 max-w-lg w-full">
        <h2 class="text-2xl font-black mb-4">How to Play</h2>
        <div class="space-y-3 text-sm text-on-surface-variant leading-relaxed">
            <p><strong class="text-on-surface">Click</strong> any white cell to select it. The active word will be highlighted.</p>
            <p><strong class="text-on-surface">Type</strong> a letter to fill the cell and advance to the next.</p>
            <p><strong class="text-on-surface">Click</strong> the same cell again to toggle between Across and Down.</p>
            <p>Use <strong class="text-on-surface">Arrow Keys</strong> to navigate, <strong class="text-on-surface">Backspace</strong> to delete.</p>
            <p>Click <strong class="text-on-surface">Check Solve</strong> to verify your solution.</p>
        </div>
        <button id="help-close" class="mt-6 bg-primary text-on-primary px-6 py-2 text-xs font-bold tracking-widest uppercase hover:bg-primary-dim transition-all active:scale-95">
            Got it
        </button>
    </div>
</div>
